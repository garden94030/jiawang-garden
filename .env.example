# 後端環境變數 (複製此檔為 .env 並填入實際值)

# 伺服器設定
PORT=3001
NODE_ENV=development

# JWT 密鑰 (請使用強隨機字串，至少64字元)
JWT_SECRET=your-very-strong-secret-key-at-least-64-characters-long-replace-this

# JWT 有效期限
JWT_EXPIRES_IN=8h

# 管理員初始帳號 (首次執行後請在後台修改)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe@2024!

# CORS 允許來源 (正式環境請填寫實際網域)
CORS_ORIGIN=http://localhost:5173

# 上傳檔案設定
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# 資料庫路徑
DB_PATH=./data/heche.db
